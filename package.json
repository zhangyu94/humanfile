{
  "name": "humanfile-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "typecheck": "tsc",
    "release:core": "pnpm --filter humanfile run release",
    "release:action": "pnpm --filter @humanfile/action run release",
    "prepare": "simple-git-hooks",
    "up": "taze major -I",
    "humanfile": "node packages/core/dist/cli.mjs"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.10.0",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
